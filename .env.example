# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
# Used in vite.config.ts and exposed to frontend via process.env.GEMINI_API_KEY
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ImageKit Configuration - Backend (used in server.ts)
IMAGEKIT_PUBLIC_KEY="public_71xCzGlh+6p2e0Lme57TV5oiG7M="
IMAGEKIT_PRIVATE_KEY="private_VNUETeRElBAxrarp1sxF78da0i0="
IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/osj1lakjx"

# ImageKit Configuration - Frontend (used in React components via import.meta.env)
# These must be prefixed with VITE_ to be exposed to the client-side code
VITE_IMAGEKIT_PUBLIC_KEY="public_71xCzGlh+6p2e0Lme57TV5oiG7M="
VITE_IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/osj1lakjx"
