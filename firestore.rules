rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Logs: Any authenticated user can read, only system/verified can write (simulated here with basic auth)
    match /logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.actor == request.auth.token.name;
    }

    // Institutions: Authenticated users can read
    match /institutions/{institutionId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); 
    }

    // AI Services: Authenticated users can read and write
    match /ai_services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
